body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #e3f2fd;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

.game {
  text-align: center;
  background: white;
  padding: 20px;
  border-radius: 10px;
  box-shadow: 0 4px 10px rgba(0,0,0,0.2);
}

h1 {
  color: #1565c0;
}

button {
  padding: 10px 20px;
  border: none;
  background: #1565c0;
  color: white;
  border-radius: 5px;
  cursor: pointer;
}

button:hover {
  background: #0d47a1;
}
